# Environment Configuration Template
# Copy this file to .env.development, .env.staging, .env.production, or .env.test
# and fill in the appropriate values for each environment

# Server Configuration
NODE_ENV=development
DOMAIN=
HOST=0.0.0.0
PORT=4000

# Database Configuration
DB_NAME=your_database_name
DB_USER_NAME=your_database_username
DB_PASSWORD=your_database_password
DB_HOST=your_database_host
DB_PORT=3306
DB_LOGGING=false

# JWT Configuration
JWT_TOKEN_SECRET=your_jwt_secret_here

# Nodemailer Configuration
NODEMAILER_EMAIL=your_email
NODEMAILER_PASSWORD=your_email_password

# Azure Blob Storage Configuration
AZURE_BLOB_KEY=your_azure_blob_key_here
AZURE_BLOB_CONNECTION_STRING=your_azure_connection_string_here
AZURE_CONTAINER_NAME=your_container_name

# Google Maps (Distance Matrix API for shipping distance / serviceability)
# Use an API key from Cloud Console > Credentials > Create credentials > API key (not a service account private key)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_ENABLED=true
GOOGLE_MAPS_TIMEOUT=5000
GOOGLE_MAPS_MODE=driving
GOOGLE_MAPS_UNITS=metric
GOOGLE_MAPS_HAVERSINE_BUFFER=1.3

# Distance cache TTL (seconds, default 24h)
ROAD_DISTANCE_CACHE_TTL=86400

# FCM / Firebase
# Recommended: use split env vars instead of embedding full JSON
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
# Use \n for newlines in the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
